# Optional local overrides for VioWrapper
VIO_WRAPPER_CONFIG_PATH=/Users/visen24/.openclaw-assistant-ui/openclaw.json
VIO_WRAPPER_PROJECT_ROOT=/Volumes/2TB/clawd
VIO_WRAPPER_PORT=8789
VIO_WRAPPER_GATEWAY_PORT=18790
# Prefer keeping the token in local shell env or launchd, not committed files.
VIO_WRAPPER_GATEWAY_TOKEN=replace-me
# Optional explicit gateway URL override
# VIO_WRAPPER_GATEWAY_URL=ws://127.0.0.1:18790
