# Optional local overrides for VioDashboard
# Copy machine-specific values into config/local.mjs when possible.
VIO_WRAPPER_CONFIG_PATH=/Users/yourname/.openclaw-assistant-ui/openclaw.json
VIO_WRAPPER_PROJECT_ROOT=/Users/yourname/MAS
VIO_OPENCLAW_REPO_ROOT=/Users/yourname/MAS/openclaw_fork
VIO_WRAPPER_PORT=8789
VIO_WRAPPER_GATEWAY_PORT=18790
# Prefer keeping the token in local shell env or launchd, not committed files.
VIO_WRAPPER_GATEWAY_TOKEN=replace-me
# Optional explicit gateway URL override
# VIO_WRAPPER_GATEWAY_URL=ws://127.0.0.1:18790
